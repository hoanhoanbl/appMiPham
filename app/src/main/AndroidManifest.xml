<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppBanMyPham">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.AppBanMyPham">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.AppBanMyPham" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.AppBanMyPham" />
        <activity android:name=".ui.admin.DashboardActivity"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.product.ProductActivity"/>
        <activity android:name=".ui.admin.ManageProductActivity" />
        <activity android:name=".ui.admin.ManageBrandActivity" />
        <activity android:name=".ui.admin.ManageSpaPackageActivity" />
        <activity android:name=".ui.admin.ManageSpaAppointmentActivity" />
        <activity android:name=".ui.admin.ManageTreatmentActivity" />
        <activity android:name=".ui.consultant.ConsultantDashboardActivity" />
        <activity android:name=".ui.consultant.ConsultantAppointmentDetailActivity" />
        <activity android:name=".ui.consultant.ConsultantChatActivity" />
        <activity android:name=".ui.consultant.ConsultantCustomerProfileActivity" />
        <activity android:name=".ui.cart.CartActivity"/>
        <activity
            android:name=".ui.product.ProductDetailsActivity"
            android:exported="false"
            android:parentActivityName=".ui.product.ProductActivity" />
        <activity
            android:name=".ui.product.SpaPackageDetailsActivity"
            android:exported="false"
            android:parentActivityName=".ui.product.ProductActivity" />
        <activity
            android:name=".ui.product.BookSpaAppointmentActivity"
            android:exported="false"
            android:parentActivityName=".ui.product.SpaPackageDetailsActivity" />
        <activity
            android:name=".ui.product.CustomerTreatmentPlanActivity"
            android:exported="false"
            android:parentActivityName=".ui.product.ProductActivity" />
        <activity
            android:name=".ui.product.CustomerAppointmentChatActivity"
            android:exported="false"
            android:parentActivityName=".ui.product.ProductActivity" />
        <activity android:name=".ui.checkout.CheckoutActivity"
            android:windowSoftInputMode="adjustResize"/>
        <activity android:name=".ui.admin.ManageOrderActivity" />
        <activity
            android:name=".ui.admin.ManageReviewActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.admin.ManageReturnActivity"
            android:exported="false" />

    </application>

</manifest>
